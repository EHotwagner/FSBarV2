<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Library</OutputType>
    <IsPackable>true</IsPackable>
    <PackageId>Broker.Protocol</PackageId>
    <Description>gRPC server adapter hosting the ProxyLink and ScriptingClient services on a single Kestrel listener.</Description>
    <!-- net10 SDK ships AspNetCore prune-package metadata only for matching frameworks; suppress until 10.0.x SDKs catch up. -->
    <AllowMissingPrunePackageData>true</AllowMissingPrunePackageData>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="VersionHandshake.fsi" />
    <Compile Include="VersionHandshake.fs" />
    <Compile Include="BackpressureGate.fsi" />
    <Compile Include="BackpressureGate.fs" />
    <Compile Include="WireConvert.fsi" />
    <Compile Include="WireConvert.fs" />
    <Compile Include="BrokerState.fsi" />
    <Compile Include="BrokerState.fs" />
    <Compile Include="ProxyLinkService.fsi" />
    <Compile Include="ProxyLinkService.fs" />
    <Compile Include="ScriptingClientService.fsi" />
    <Compile Include="ScriptingClientService.fs" />
    <Compile Include="ServerHost.fsi" />
    <Compile Include="ServerHost.fs" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Broker.Contracts\Broker.Contracts.fsproj" />
    <ProjectReference Include="..\Broker.Core\Broker.Core.fsproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.AspNetCore.Server" Version="2.76.0" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Extensions.Logging" Version="10.0.0" />
  </ItemGroup>

</Project>
