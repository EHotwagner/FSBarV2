<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <GenerateProgramFile>false</GenerateProgramFile>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="UpdateTests.fs" />
    <Compile Include="ViewTests.fs" />
    <Compile Include="RuntimeTests.fs" />
    <Compile Include="HubRetirementGuardTests.fs" />
    <Compile Include="CarveoutT029Tests.fs" />
    <Compile Include="CarveoutT037Tests.fs" />
    <Compile Include="CarveoutT042Tests.fs" />
    <Compile Include="CarveoutT046Tests.fs" />
    <Compile Include="CmdInspectionTests.fs" />
