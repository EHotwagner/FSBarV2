    <Compile Include="WorkedExampleTests.fs" />
    <Compile Include="Program.fs" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Fixtures/*.txt" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Broker.Mvu\Broker.Mvu.fsproj" />
    <ProjectReference Include="..\..\src\Broker.Core\Broker.Core.fsproj" />
    <ProjectReference Include="..\..\src\Broker.Protocol\Broker.Protocol.fsproj" />
